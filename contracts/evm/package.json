{
  "name": "nft-platform-evm-contracts",
  "version": "1.0.0",
  "description": "EVM smart contracts for NFT platform",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:polygon-mumbai": "hardhat run scripts/deploy.ts --network polygon-mumbai",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhat",
    "verify:sepolia": "hardhat verify --network sepolia"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "ethers": "^6.14.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.13",
    "hardhat": "^2.22.0",
    "typescript": "5.2.2",
    "dotenv": "^16.3.1",
    "@types/node": "^20.9.0",
    "ts-node": "^10.9.1"
  }
}