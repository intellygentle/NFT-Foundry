# ============================================================
# NFT Foundry — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local:
#   cp frontend/.env.local.example frontend/.env.local
# ============================================================


# The URL of your running backend.
# For local dev this never changes.
NEXT_PUBLIC_API_URL=http://localhost:3001


# Required for the EVM wallet connect modal (RainbowKit).
# Get a free Project ID at: https://cloud.walletconnect.com
#   → Create Project → Type: App → copy the Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID_HERE


# Optional — Solana RPC. Default public devnet is fine for local testing.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com