# ============================================================
# NFT Foundry — Backend Environment Variables
# ============================================================

PORT=3001
NODE_ENV=development


# ── Shelby ──────────────────────────────────────────────────
# STEP 1 — Generate your uploader account (run once):
#   cd backend && node -e "
#   const { Account } = require('@aptos-labs/ts-sdk');
#   const a = Account.generate();
#   console.log('Address    :', a.accountAddress.toString());
#   console.log('Private Key:', a.privateKey.toString());
#   "
#   → Paste Private Key below, save Address for the faucet

SHELBY_PRIVATE_KEY=ed25519-priv-0xYOUR_PRIVATE_KEY_HERE

# STEP 2 — Fund your account with APT + ShelbyUSD (testnet faucet):
#   https://docs.shelby.xyz/sdks/typescript/node/guides/uploading-file
#   → Scroll to the Faucet widget → paste your Address from Step 1

# STEP 3 — Get an API key:
#   https://geomi.dev → API Resource → Testnet → Submit → copy key
SHELBY_API_KEY=aptoslabs_YOUR_KEY_HERE

SHELBY_NETWORK=shelbynet


# ── EVM (Sepolia) ────────────────────────────────────────────
# RPC URL — get free from https://infura.io or https://alchemy.com
EVM_RPC_URL=https://sepolia.infura.io

EVM_CHAIN_ID=11155111

# Private key — use a dedicated deployer wallet, not your main wallet.
# Export from MetaMask: Account Details → Export Private Key
# Fund with Sepolia ETH: https://faucet.quicknode.com/ethereum/sepolia
EVM_PRIVATE_KEY=af292a37603196c55532786721df9c7fa9533f727bb93e0e9b728a7895d27d06

# Fill in AFTER running: cd contracts/evm && npm run deploy:sepolia
# Address is printed in terminal and saved to contracts/evm/deployed-addresses.json
EVM_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Optional — for contract verification on Etherscan
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE


# ── Polygon Mumbai (optional) ────────────────────────────────
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com
# Fill in AFTER: cd contracts/evm && npm run deploy:polygon-mumbai
POLYGON_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY_HERE


# ── Solana Devnet (optional) ─────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Generate keypair:  solana-keygen new --outfile ~/nft-foundry.json --no-bip39-passphrase
# Encode to base64:  cat ~/nft-foundry.json | base64
# Fund devnet SOL:   solana airdrop 2 $(solana-keygen pubkey ~/nft-foundry.json) --url devnet
SOLANA_PRIVATE_KEY=YOUR_BASE64_ENCODED_KEYPAIR_JSON_HERE


# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001